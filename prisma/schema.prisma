generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        Int          @id @default(autoincrement())
  nombreRol String       @unique @map("nombre_rol") @db.VarChar(50)
  estado    Boolean      @default(true)
  usuarios  UsuarioRol[]

  @@map("roles")
}

model Usuario {
  id              Int               @id @default(autoincrement())
  nombreCompleto  String            @map("nombre_completo") @db.VarChar(150)
  email           String            @unique @db.VarChar(150)
  passwordHash    String            @map("password_hash") @db.VarChar(255)
  estado          Boolean           @default(true)
  porcentajeComision Decimal?       @default(0.00) @map("porcentaje_comision") @db.Decimal(5, 2)
  fechaRegistro   DateTime          @default(now()) @map("fecha_registro")
  roles           UsuarioRol[]
  citasMedico     Cita[]            @relation("CitasMedico")
  pagosCobrador   Pago[]            @relation("PagosCobrador")
  campanasCreadas CampanaWhatsapp[] @relation("CampanasCreadas")
  planesMedico    PlanTratamiento[]

  @@map("usuarios")
}

model UsuarioRol {
  id        Int     @id @default(autoincrement())
  usuarioId Int     @map("usuario_id")
  rolId     Int     @map("rol_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  rol       Role    @relation(fields: [rolId], references: [id])

  @@map("usuario_roles")
}

model Paciente {
  id               Int       @id @default(autoincrement())
  nombres          String    @db.VarChar(100)
  apellidos        String    @db.VarChar(100)
  numeroDocumento  String?   @map("numero_documento") @db.VarChar(20)
  fechaNacimiento  DateTime? @map("fecha_nacimiento") @db.Date
  telefonoWhatsapp String?   @map("telefono_whatsapp") @db.VarChar(20)
  alergiasCriticas String?   @map("alergias_criticas") @db.Text
  fechaRegistro    DateTime  @default(now()) @map("fecha_registro")
  estado           Boolean   @default(true)

  citas            Cita[]
  mensajesEnvio    MensajeEnvio[]
  pacientesCampana CampanaPaciente[]
  odontogramas     Odontograma[]
  planes           PlanTratamiento[]

  @@map("pacientes")
}

model CategoriaServicio {
  id              Int        @id @default(autoincrement())
  nombreCategoria String     @map("nombre_categoria") @db.VarChar(100)
  estado          Boolean    @default(true)
  servicios       Servicio[]

  @@map("categorias_servicio")
}

model Servicio {
  id             Int               @id @default(autoincrement())
  categoriaId    Int               @map("categoria_id")
  nombreServicio String            @map("nombre_servicio") @db.VarChar(150)
  descripcion    String?           @db.Text
  estado         Boolean           @default(true)
  categoria      CategoriaServicio @relation(fields: [categoriaId], references: [id])
  precios        ServicioPrecio[]
  citasServicios CitaServicio[]
  planes         PlanTratamientoServicio[]

  @@map("servicios")
}

model ServicioPrecio {
  id          Int       @id @default(autoincrement())
  servicioId  Int       @map("servicio_id")
  precio      Decimal   @db.Decimal(10, 2)
  fechaInicio DateTime  @map("fecha_inicio") @db.Date
  fechaFin    DateTime? @map("fecha_fin") @db.Date
  estado      Boolean   @default(true)
  servicio    Servicio  @relation(fields: [servicioId], references: [id])

  @@map("servicio_precios")
}

model EstadoCita {
  id           Int    @id @default(autoincrement())
  nombreEstado String @unique @map("nombre_estado") @db.VarChar(50)
  citas        Cita[]

  @@map("estados_cita")
}

model Cita {
  id              Int                      @id @default(autoincrement())
  pacienteId      Int                      @map("paciente_id")
  medicoId        Int                      @map("medico_id")
  estadoCitaId    Int                      @map("estado_cita_id")
  planServicioId  Int?                     @map("plan_servicio_id")
  fechaHoraInicio DateTime                 @map("fecha_hora_inicio")
  fechaHoraFin    DateTime                 @map("fecha_hora_fin")
  motivoPrincipal String?                  @map("motivo_principal") @db.VarChar(200)
  observaciones   String?                  @db.Text
  fechaRegistro   DateTime                 @default(now()) @map("fecha_registro")
  paciente        Paciente                 @relation(fields: [pacienteId], references: [id])
  medico          Usuario                  @relation("CitasMedico", fields: [medicoId], references: [id])
  estadoCita      EstadoCita               @relation(fields: [estadoCitaId], references: [id])
  planServicio    PlanTratamientoServicio? @relation(fields: [planServicioId], references: [id])
  servicios       CitaServicio[]
  pagos           Pago[]
  mensajesEnvio   MensajeEnvio[]
  odontogramas    Odontograma[]

  @@map("citas")
}

model CitaServicio {
  id         Int      @id @default(autoincrement())
  citaId     Int      @map("cita_id")
  servicioId Int      @map("servicio_id")
  cantidad   Int      @default(1)
  descuento  Decimal  @default(0.00) @db.Decimal(10, 2)
  cita       Cita     @relation(fields: [citaId], references: [id])
  servicio   Servicio @relation(fields: [servicioId], references: [id])

  @@map("cita_servicios")
}

model MetodoPago {
  id           Int     @id @default(autoincrement())
  nombreMetodo String  @unique @map("nombre_metodo") @db.VarChar(50)
  estado       Boolean @default(true)
  pagos        Pago[]

  @@map("metodos_pago")
}

model Pago {
  id                Int        @id @default(autoincrement())
  citaId            Int        @map("cita_id")
  usuarioCobradorId Int        @map("usuario_cobrador_id")
  metodoPagoId      Int        @map("metodo_pago_id")
  montoPagado       Decimal    @map("monto_pagado") @db.Decimal(10, 2)
  numeroOperacion   String?    @map("numero_operacion") @db.VarChar(100)
  observacion       String?    @db.Text
  fechaPago         DateTime   @default(now()) @map("fecha_pago")
  estado            Boolean    @default(true)
  cita              Cita       @relation(fields: [citaId], references: [id])
  usuarioCobrador   Usuario    @relation("PagosCobrador", fields: [usuarioCobradorId], references: [id])
  metodoPago        MetodoPago @relation(fields: [metodoPagoId], references: [id])

  @@map("pagos")
}

model PlantillaMensaje {
  id              Int            @id @default(autoincrement())
  nombrePlantilla String         @map("nombre_plantilla") @db.VarChar(100)
  tipoMensaje     String         @map("tipo_mensaje") @db.VarChar(80)
  contenido       String         @db.Text
  estado          Boolean        @default(true)
  mensajesEnvio   MensajeEnvio[]

  @@map("plantillas_mensajes")
}

model EstadoEnvioMensaje {
  id               Int               @id @default(autoincrement())
  nombreEstado     String            @unique @map("nombre_estado") @db.VarChar(50)
  mensajesEnvio    MensajeEnvio[]
  campanaPacientes CampanaPaciente[]

  @@map("estados_envio_mensaje")
}

model MensajeEnvio {
  id                  Int                @id @default(autoincrement())
  plantillaId         Int                @map("plantilla_id")
  pacienteId          Int                @map("paciente_id")
  citaId              Int?               @map("cita_id")
  estadoEnvioId       Int                @map("estado_envio_id")
  fechaHoraProgramada DateTime           @map("fecha_hora_programada")
  fechaHoraEnvio      DateTime?          @map("fecha_hora_envio")
  errorDetalle        String?            @map("error_detalle") @db.Text
  plantilla           PlantillaMensaje   @relation(fields: [plantillaId], references: [id])
  paciente            Paciente           @relation(fields: [pacienteId], references: [id])
  cita                Cita?              @relation(fields: [citaId], references: [id])
  estadoEnvio         EstadoEnvioMensaje @relation(fields: [estadoEnvioId], references: [id])

  @@map("mensajes_envio")
}

model CampanaWhatsapp {
  id               Int               @id @default(autoincrement())
  nombreCampana    String            @map("nombre_campana") @db.VarChar(150)
  descripcion      String?           @db.Text
  usuarioCreadorId Int               @map("usuario_creador_id")
  fechaCreacion    DateTime          @default(now()) @map("fecha_creacion")
  estado           Boolean           @default(true)
  usuarioCreador   Usuario           @relation("CampanasCreadas", fields: [usuarioCreadorId], references: [id])
  pacientes        CampanaPaciente[]

  @@map("campanas_whatsapp")
}

model CampanaPaciente {
  id            Int                @id @default(autoincrement())
  campanaId     Int                @map("campana_id")
  pacienteId    Int                @map("paciente_id")
  estadoEnvioId Int                @map("estado_envio_id")
  fechaEnvio    DateTime?          @map("fecha_envio")
  campana       CampanaWhatsapp    @relation(fields: [campanaId], references: [id])
  paciente      Paciente           @relation(fields: [pacienteId], references: [id])
  estadoEnvio   EstadoEnvioMensaje @relation(fields: [estadoEnvioId], references: [id])

  @@map("campana_pacientes")
}

model PiezaDental {
  id          Int                  @id @default(autoincrement())
  codigoFdi   String               @unique @map("codigo_fdi") @db.VarChar(5)
  nombrePieza String               @map("nombre_pieza") @db.VarChar(100)
  tipoPieza   String               @map("tipo_pieza") @db.VarChar(50)
  cuadrante   Int
  arcada      String               @db.VarChar(20)
  lado        String               @db.VarChar(20)
  posicion    Int
  estado      Boolean              @default(true)
  detalles    OdontogramaDetalle[]

  @@map("piezas_dentales")
}

model SuperficieDental {
  id               Int                  @id @default(autoincrement())
  nombreSuperficie String               @map("nombre_superficie") @db.VarChar(50)
  abreviatura      String               @db.VarChar(5)
  detalles         OdontogramaDetalle[]

  @@map("superficies_dentales")
}

model EstadoPiezaDental {
  id           Int                  @id @default(autoincrement())
  nombreEstado String               @unique @map("nombre_estado") @db.VarChar(80)
  detalles     OdontogramaDetalle[]

  @@map("estados_pieza_dental")
}

model Odontograma {
  id                 Int                  @id @default(autoincrement())
  pacienteId         Int                  @map("paciente_id")
  citaId             Int?                 @map("cita_id")
  fechaRegistro      DateTime             @default(now()) @map("fecha_registro")
  observacionGeneral String?              @map("observacion_general") @db.Text
  paciente           Paciente             @relation(fields: [pacienteId], references: [id])
  cita               Cita?                @relation(fields: [citaId], references: [id])
  detalles           OdontogramaDetalle[]

  @@map("odontogramas")
}

model OdontogramaDetalle {
  id                     Int                      @id @default(autoincrement())
  odontogramaId          Int                      @map("odontograma_id")
  piezaDentalId          Int                      @map("pieza_dental_id")
  superficieId           Int?                     @map("superficie_id")
  estadoPiezaId          Int                      @map("estado_pieza_id")
  diagnostico            String?                  @db.Text
  tratamientoRecomendado String?                  @map("tratamiento_recomendado") @db.Text
  observacion            String?                  @db.Text
  odontograma            Odontograma              @relation(fields: [odontogramaId], references: [id])
  piezaDental            PiezaDental              @relation(fields: [piezaDentalId], references: [id])
  superficie             SuperficieDental?        @relation(fields: [superficieId], references: [id])
  estadoPieza            EstadoPiezaDental        @relation(fields: [estadoPiezaId], references: [id])
  planServicios          PlanTratamientoServicio[]

  @@map("odontograma_detalles")
}

model PlanTratamiento {
  id            Int                        @id @default(autoincrement())
  pacienteId    Int                        @map("paciente_id")
  medicoId      Int                        @map("medico_id")
  estado        String                     @default("pendiente") @db.VarChar(20)
  fechaCreacion DateTime                   @default(now()) @map("fecha_creacion")
  observaciones String?                    @db.Text
  paciente      Paciente                   @relation(fields: [pacienteId], references: [id])
  medico        Usuario                    @relation(fields: [medicoId], references: [id])
  servicios     PlanTratamientoServicio[]

  @@map("planes_tratamiento")
}

model PlanTratamientoServicio {
  id                   Int                 @id @default(autoincrement())
  planId               Int                 @map("plan_id")
  servicioId           Int                 @map("servicio_id")
  cantidad             Int                 @default(1)
  descuento            Decimal             @default(0.00) @db.Decimal(10, 2)
  ejecutado            Boolean             @default(false)
  odontogramaDetalleId Int?                @map("odontograma_detalle_id")
  plan                 PlanTratamiento     @relation(fields: [planId], references: [id])
  servicio             Servicio            @relation(fields: [servicioId], references: [id])
  odontogramaDetalle   OdontogramaDetalle? @relation(fields: [odontogramaDetalleId], references: [id])
  citas                Cita[]

  @@map("plan_tratamiento_servicios")
}
